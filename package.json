{
  "name": "yvette-squash",
  "version": "0.1.0",
  "private": true,
  "description": "Appli de réservation de terrains de squash (front amélioré + journal partagé) au-dessus de ResaMania",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma db push --skip-generate --accept-data-loss && next build",
