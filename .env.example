# ============================================================================
#  Variables d'environnement — Squash de l'Yvette
#  Dev : copier ce fichier vers .env. Prod (Vercel) : les définir dans
#  Project Settings › Environment Variables (ne JAMAIS committer de vraie valeur).
# ============================================================================

# --- Base de données PostgreSQL (Neon) ---
# DATABASE_URL = connexion « pooled » (le host contient -pooler) → requêtes à l'exécution
# DIRECT_URL   = connexion directe (host sans -pooler)          → prisma db push / migrations
# Les deux chaînes sont affichées dans le dashboard Neon (bouton « Connect »).
DATABASE_URL="postgresql://user:pwd@ep-xxx-pooler.REGION.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:pwd@ep-xxx.REGION.aws.neon.tech/dbname?sslmode=require"

# --- Chiffrement des identifiants ResaMania (AES-256-GCM) ---
# Générer une clé : openssl rand -base64 32
CREDENTIALS_SECRET=""

# --- ResaMania (API interne) ---
RESA_API_BASE_URL="https://api.resamania.com"
RESA_TENANT="lecomplexbures"
RESA_CLUB_ID="/lecomplexbures/clubs/2345"
RESA_ACTIVITY_ID="/lecomplexbures/activities/30592"
RESA_CLIENT_ID=""          # 142_… (récupéré depuis le HAR)
RESA_CLIENT_SECRET=""      # secret OAuth (récupéré depuis le HAR)
RESA_REDIRECT_URI="https://member.resamania.com/lecomplexbures/"

# 1 = planning factice (dev sans toucher ResaMania) ; 0 ou absent = vraies données
RESA_USE_MOCK="0"

# --- Envoi des e-mails : codes OTP + commentaires (SMTP Gmail) ---
# Compte Gmail expéditeur + « mot de passe d'application » (Compte Google → Sécurité →
# Validation en 2 étapes → Mots de passe des applications). Gratuit, sans domaine à
# vérifier, et bonne délivrabilité (l'envoi part de gmail.com).
GMAIL_USER="ton-adresse@gmail.com"
GMAIL_APP_PASSWORD=""          # 16 caractères (les espaces sont tolérés)
# Destinataire des commentaires (par défaut : plenat.thomas@gmail.com)
FEEDBACK_TO_EMAIL="plenat.thomas@gmail.com"

# --- Notifications Web Push (alertes « créneau libéré ») ---
# Générer les clés VAPID une fois : npx web-push generate-vapid-keys
# La clé PUBLIQUE est aussi lue côté navigateur → préfixe NEXT_PUBLIC_ obligatoire.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:ton-email@example.com"

# Protège les endpoints cron /api/cron/* (Vercel Cron envoie
# « Authorization: Bearer $CRON_SECRET » ; un cron externe peut utiliser ?token=$CRON_SECRET).
# Générer : openssl rand -hex 24
CRON_SECRET=""

# --- Compte « de service » ResaMania (préchauffage du cache planning) ---
# Identifiants ResaMania d'UN compte dédié : le cron /api/cron/warm-planning s'y connecte
# pour remplir le cache du planning (vu par les comptes « email seul »). Indépendant des
# sessions des membres. Sans ces variables, le préchauffage ne fait rien.
RESA_CRON_USER=""       # ex. ton identifiant ResaMania (email)
RESA_CRON_PASSWORD=""   # mot de passe ResaMania du compte de service
