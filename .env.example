# --- Base de données ---
# Dev : SQLite local. Prod : remplacer par l'URL Postgres Neon (et passer provider="postgresql" dans schema.prisma)
DATABASE_URL="file:./dev.db"

# --- Chiffrement des identifiants ResaMania (AES-256-GCM) ---
# Générer une clé : openssl rand -base64 32
CREDENTIALS_SECRET=""

# --- ResaMania (à compléter depuis le HAR) ---
# URL de base de l'API interne, ex. https://api.resamania2.com  (À CONFIRMER via le HAR)
RESA_API_BASE_URL=""
RESA_TENANT="lecomplexbures"
RESA_CLUB_ID="/lecomplexbures/clubs/2345"

# Tant que l'API n'est pas branchée, on affiche un planning factice pour développer l'UI
RESA_USE_MOCK="1"
