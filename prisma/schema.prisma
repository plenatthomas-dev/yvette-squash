// Schéma de la base. Prod + dev = PostgreSQL (Neon).
// DATABASE_URL = connexion « pooled » (runtime serverless) ; DIRECT_URL = connexion directe
// (utilisée par prisma db push / migrations). Les deux sont fournies par le dashboard Neon.
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"] // rhel = runtime des fonctions Vercel
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Un joueur de l'appli, identifié par son compte ResaMania (contactId).
model User {
  id          String       @id @default(cuid())
  contactId   String?      @unique // ResaMania (nullable : un compte « email seul » n'en a pas encore)
  displayName String
  nickname    String? // pseudonyme choisi par le joueur (affiché à la place du prénom)
  email       String?      @unique // normalisé (trim+lowercase) — CLÉ D'IDENTITÉ commune ResaMania/email
  // Annuaire (idée 6) : visibilité OPT-OUT — visible par défaut, le joueur peut se retirer
  // depuis ses paramètres. Base légale = intérêt légitime (entraide asso) + retrait facile.
  // Seuls `id` + nom/pseudo sont exposés par /api/directory (jamais email ni contactId).
  listed      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  sessions    Session[]
  bookings    Booking[]
  attendances Attendance[]
  pushSubs    PushSubscription[]
  slotAlerts  SlotAlert[]
  expensesPaid    Expense[]      @relation("ExpensePayer")
  expensesCreated Expense[]      @relation("ExpenseCreator")
  expenseShares   ExpenseShare[]
  tricountApprovals TricountApproval[]
  tricountComments  TricountComment[]
  // Délégation temporaire de droits (idée 4) : ce que je donne / ce qu'on me donne.
  delegationsGiven    Delegation[] @relation("DelegationGiven")
  delegationsReceived Delegation[] @relation("DelegationReceived")
  // Tournois (idée 3) : ceux que j'ai créés + les participations où je suis membre.
  tournamentsCreated  Tournament[]       @relation("TournamentCreator")
  tournamentPlayers   TournamentPlayer[]
  // Classement fédéral (idée squashnet) : dernier classement rapproché, source publique.
  squashnetRanking    SquashnetRanking?
}

// Session applicative (cookie httpOnly). Garde le refresh token CHIFFRÉ pour réémettre
// des access tokens sans redemander le mot de passe tant que la session est valide.
model Session {
  id              String   @id // jeton aléatoire (valeur du cookie)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  // Champs ResaMania : NULL pour une session « email seul » (aucun jeton).
  accessToken     String? // token Bearer chiffré (AES-256-GCM, court ~1h)
  refreshTokenEnc String? // refresh token chiffré (AES-256-GCM)
  tokenExpiresAt  DateTime?
  identityJson    String? // ResaIdentity sérialisée (contactId, clubId, nom…)
  expiresAt       DateTime // expiration de la session applicative
  createdAt       DateTime @default(now())

  @@index([userId])
}

// Journal partagé : chaque réservation faite via l'appli (alimente « qui a réservé quoi »).
model Booking {
  id           String   @id @default(cuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  attendeeId   String? // IRI de l'attendee ResaMania (pour annuler)
  classEventId String // IRI du class_event réservé
  courtName    String
  startsAt     DateTime
  endsAt       DateTime
  status       String   @default("booked") // booked | cancelled
  createdAt    DateTime @default(now())
  // Délégation (idée 4) : qui a physiquement déclenché l'action, si différent de `userId`
  // (le propriétaire réel de la résa ResaMania reste `userId` = le délégant). NULL = résa
  // faite pour soi-même. Pas de relation Prisma formelle (comme `PlanningSnapshot.updatedById`).
  actingUserId String?

  // Une seule ligne par (joueur, créneau) : empêche les doublons de réservation.
  // book/route.ts fait un upsert sur cette clé (rebooking = on repasse la même ligne
  // en "booked"), donc l'historique n'accumule jamais 2 lignes pour le même créneau.
  @@unique([userId, classEventId])
  @@index([startsAt])
  @@index([userId])
}

// Tentative de connexion ÉCHOUÉE (rate limiting du login : 5 max / 15 min par IP).
// Une ligne par échec ; les lignes sont purgées dès qu'elles sortent de la fenêtre,
// et toutes celles d'une IP sont effacées quand elle réussit à se connecter.
model LoginAttempt {
  id        String   @id @default(cuid())
  ip        String
  createdAt DateTime @default(now())

  @@index([ip, createdAt])
}

// Commentaire envoyé par e-mail (rate limiting : 10 max / 24 h par membre).
// Une ligne par envoi réussi ; purgées dès qu'elles sortent de la fenêtre de 24 h.
// Table autonome (userId brut, sans relation) comme LoginAttempt : simple compteur.
model FeedbackMessage {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// Code OTP (6 chiffres) pour la connexion « email seul » — preuve de possession de l'email.
// Le code n'est JAMAIS stocké en clair (HMAC-SHA256). Usage unique, court, rate-limité
// à la fois PAR EMAIL (anti-spam d'une boîte) et PAR IP (anti-abus d'envoi : empêche une
// source d'arroser des centaines d'adresses et de brûler le quota d'envoi Gmail).
model EmailOtp {
  id        String   @id @default(cuid())
  email     String // normalisé (trim+lowercase)
  codeHash  String // HMAC-SHA256 du code
  ip        String? // IP demandeuse (rate limiting par IP ; nullable pour l'existant)
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ip, createdAt])
}

// Cache du planning d'un jour, rafraîchi à chaque chargement par un membre à jeton
// ResaMania. Sert à afficher le planning aux comptes « email seul » (sans jeton), qui
// le ré-annotent en direct (présences). payloadJson = PlanningDay BRUT (avant annotation).
model PlanningSnapshot {
  date        String   @id // "YYYY-MM-DD"
  payloadJson String
  updatedById String? // dernier membre (à jeton) ayant rafraîchi le snapshot
  updatedAt   DateTime @updatedAt
}

// Présence « asso » sur un créneau déjà réservé par un membre : signal purement local
// (ne touche jamais ResaMania ni l'identité du réservataire). Un membre peut se noter
// présent sur le créneau d'un autre ; un second clic le retire.
model Attendance {
  id           String   @id @default(cuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  classEventId String // IRI du class_event concerné (clé de jointure avec le planning)
  startsAt     DateTime // horaire du créneau : sert à interdire 2 présences au même horaire
  createdAt    DateTime @default(now())

  @@unique([userId, classEventId]) // une présence par personne et par créneau
  @@index([classEventId])
  @@index([startsAt]) // purge des présences anciennes
}

// Abonnement Web Push (un par appareil/navigateur). Sert à envoyer les alertes.
model PushSubscription {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  endpoint  String   @unique
  p256dh    String // clé publique du client (chiffrement Web Push)
  auth      String // secret d'authentification
  createdAt DateTime @default(now())

  @@index([userId])
}

// Alerte « préviens-moi si un terrain se libère » pour une date + un horaire (HH:MM).
// Le cron interroge ResaMania et pousse une notif dès qu'un créneau redevient réservable.
model SlotAlert {
  id         String    @id @default(cuid())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  date       String // "YYYY-MM-DD" (jour visé)
  hm         String // "HH:MM" (début du créneau visé)
  active     Boolean   @default(true)
  notifiedAt DateTime?
  createdAt  DateTime  @default(now())

  @@unique([userId, date, hm]) // une seule alerte par créneau et par joueur
  @@index([active, date])
}

// Délégation temporaire de droits de réservation (idée 4, cf. docs/delegation-droits.md) :
// le délégant autorise le délégué à réserver/annuler en son nom pendant une fenêtre bornée.
// La résa réelle reste sous l'identité ResaMania du délégant (jamais de partage de mot de
// passe) — cf. `getResaTokenForUser` — et `Booking.actingUserId` trace qui a agi. « Un seul
// délégué actif à la fois » (v1) est imposé en application, pas en base (pas de contrainte
// unique praticable sur une condition dépendant de l'heure courante).
model Delegation {
  id          String    @id @default(cuid())
  delegator   User      @relation("DelegationGiven", fields: [delegatorId], references: [id], onDelete: Cascade)
  delegatorId String
  delegate    User      @relation("DelegationReceived", fields: [delegateId], references: [id], onDelete: Cascade)
  delegateId  String
  scope       String    @default("book_cancel") // v1 : "book_cancel" uniquement (pas plus large)
  expiresAt   DateTime // borne dure (24h à 5j côté UI) — limite le rayon si compromis
  revokedAt   DateTime? // révocation manuelle par le délégant, avant expiresAt
  // Push « délégation terminée » envoyé au délégataire (révocation OU fin naturelle) :
  // marqueur d'idempotence pour ne notifier la fin qu'UNE seule fois.
  endNotifiedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([delegateId, expiresAt])
  @@index([delegatorId])
}

// ---- Partage de frais (type Tricount) ----
// Un « tricount » regroupe les dépenses d'UN jour donné (repas, sortie…) : un seul
// tricount par date, séparé des autres jours → l'historique liste ces tricounts.
// Workflow : dépenses ajoutées librement, puis chaque payeur valide (approval) ;
// quand TOUS les payeurs ont validé, les remboursements deviennent possibles.
model Tricount {
  id        String   @id @default(cuid())
  date      String   @unique // "YYYY-MM-DD" : un tricount par jour
  title     String? // libellé optionnel ("Repas d'après-match"…), fixé à la création
  createdAt DateTime @default(now())
  expenses  Expense[]
  approvals TricountApproval[]
  comments  TricountComment[]
}

// Fil de commentaires attaché à UN tricount (idée 5a) : entraide sur le partage de frais
// (« j'ai payé le pot », « il manque les balles »…). Signal purement local. Supprimé avec
// le tricount (cascade) — donc disparaît si toutes les dépenses du jour sont retirées.
model TricountComment {
  id         String   @id @default(cuid())
  tricount   Tricount @relation(fields: [tricountId], references: [id], onDelete: Cascade)
  tricountId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  body       String // texte du message
  createdAt  DateTime @default(now())

  @@index([tricountId, createdAt])
}

// « OK pour lancer les remboursements » d'un payeur sur un tricount. Les approbations
// sont remises à zéro dès que les dépenses du tricount changent (ajout/suppression).
model TricountApproval {
  id         String   @id @default(cuid())
  tricount   Tricount @relation(fields: [tricountId], references: [id], onDelete: Cascade)
  tricountId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  createdAt  DateTime @default(now())

  @@unique([tricountId, userId])
}

// Une dépense payée par un membre pour le compte de plusieurs (balles, repas, pot…).
// Montants TOUJOURS en centimes (entiers) : aucune erreur d'arrondi flottant.
// Un remboursement (A rend de l'argent à B) est une Expense `isRefund` payée par A
// avec UNE seule part portée par B : les soldes se recalculent naturellement.
model Expense {
  id          String   @id @default(cuid())
  tricount    Tricount @relation(fields: [tricountId], references: [id], onDelete: Cascade)
  tricountId  String
  // Restrict (et pas Cascade) : supprimer un membre ne doit JAMAIS effacer en
  // douce des dépenses et rééquilibrer l'historique d'argent. On bloque plutôt la
  // suppression tant que le membre a des dépenses/parts (filet de sécurité DB).
  payer       User     @relation("ExpensePayer", fields: [payerId], references: [id], onDelete: Restrict)
  payerId     String
  creator     User     @relation("ExpenseCreator", fields: [creatorId], references: [id], onDelete: Restrict)
  creatorId   String // qui a saisi la ligne (peut différer du payeur) : droit de suppression
  label       String
  amountCents Int
  isRefund    Boolean  @default(false)
  spentAt     DateTime @default(now()) // horodatage précis (affiché sur les remboursements)
  createdAt   DateTime @default(now())
  shares      ExpenseShare[]

  @@index([tricountId])
  @@index([spentAt])
}

// Part d'un participant dans une dépense (répartition égale, ajustée au centime :
// la somme des parts vaut exactement amountCents).
model ExpenseShare {
  id          String  @id @default(cuid())
  expense     Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  expenseId   String
  // Restrict : une part porte un solde ; supprimer un membre ne doit pas la faire
  // disparaître silencieusement (cf. Expense.payer/creator).
  user        User    @relation(fields: [userId], references: [id], onDelete: Restrict)
  userId      String
  amountCents Int

  @@unique([expenseId, userId])
  @@index([userId])
}

// --- Tournois (idée 3) -----------------------------------------------------
// Un tournoi = un roster (membres + invités hors asso), un format calculé (poules,
// tableau à repêchage, ou poules + phase finale) et ses matchs. Scores en JEUX gagnés.
model Tournament {
  id            String   @id @default(cuid())
  name          String?
  date          String // "YYYY-MM-DD" (comme Tricount)
  createdById   String
  createdBy     User     @relation("TournamentCreator", fields: [createdById], references: [id], onDelete: Restrict)
  status        String   @default("draft") // draft | running | done
  format        String // pools | bracket | pools_bracket
  targetMatches Int // nombre de matchs visé par joueur (2, 3 ou 4)
  bestOf        Int      @default(3) // 3 => 2 jeux gagnants ; 5 => 3 jeux gagnants
  courts        Int      @default(2)
  createdAt     DateTime @default(now())
  players       TournamentPlayer[]
  groups        TournamentGroup[]
  matches       Match[]

  @@index([date])
}

// Un participant : soit un MEMBRE (userId) soit un INVITÉ hors asso (guestName, prénom
// libre). displayName est FIGÉ à la création — supprimer un membre (userId -> null) ne
// casse pas l'historique.
model TournamentPlayer {
  id           String     @id @default(cuid())
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tournamentId String
  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId       String?
  guestName    String? // invité hors asso (null pour un membre)
  displayName  String // figé : nom du membre ou prénom de l'invité
  seed         Int?
  group        TournamentGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  groupId      String?

  @@index([tournamentId])
  @@index([userId])
}

// Une poule (round-robin). Absente pour un tournoi 100 % tableau.
model TournamentGroup {
  id           String     @id @default(cuid())
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tournamentId String
  label        String // "A", "B"...
  players      TournamentPlayer[]
  matches      Match[]

  @@index([tournamentId])
}

// Un match. En poule : rattaché à un group. En tableau : round/slot/branch + liens
// nextWin/nextLose (le vainqueur monte, le perdant bascule dans la branche de classement).
model Match {
  id           String     @id @default(cuid())
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tournamentId String
  phase        String // pool | winners | classification
  group        TournamentGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId      String?
  round        Int? // tableau : 0 = 1er tour
  slot         Int?
  branch       String? // "main" | "cons-5-8" ... (branche du tableau)
  placeLabel   String? // "Finale", "3e place", "Finale perdants"...
  // Participants (nullables : un slot de tableau se remplit quand le match amont est joué).
  player1Id    String?
  player2Id    String?
  // Résultat en JEUX gagnés.
  score1       Int?
  score2       Int?
  winnerId     String?
  status       String   @default("pending") // pending | bye | done
  courtName    String?
  order        Int? // ordre de passage global
  // Aiguillage tableau : où vont le vainqueur / le perdant.
  nextWinMatchId  String?
  nextWinSlot     Int?
  nextLoseMatchId String?
  nextLoseSlot    Int?

  @@index([tournamentId])
  @@index([groupId])
}

// Classement fédéral (FFSquash) rapproché depuis squashnet.fr (source PUBLIQUE), rafraîchi
// mensuellement par un cron. Un enregistrement par membre : présent uniquement quand le
// rapprochement nom+club est SÛR (cf. squashnet/match). L'absence = pas de classement affiché.
model SquashnetRanking {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @unique
  clt       String // classement affiché, ex. "5A", "NC"
  rang      Int? // rang national (plus petit = plus fort) — sert au tri des têtes de série
  licence   String? // n° de licence FFSquash lu sur squashnet (traçabilité)
  cat       String? // catégorie d'âge, ex. "+55", "Senior"
  club      String // libellé du club rapproché (audit)
  month     String // période de classement, "YYYY-MM-DD"
  fetchedAt DateTime @updatedAt // dernier rafraîchissement
}
